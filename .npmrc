strict-peer-dependencies=false
# `node-linker=hoisted` produces an npm-style flat node_modules instead of
# pnpm's nested .pnpm/<pkg>/node_modules layout. electron-builder's transitive-
# dependency walker silently drops some indirect deps (e.g. jwa under jws)
# from the packaged asar with the nested layout; the flat layout sidesteps
# that. Trade-off: slightly larger node_modules (no symlink dedup), but the
# packaged app is unaffected since asar packs once regardless.
node-linker=hoisted
public-hoist-pattern[]=*electron*
public-hoist-pattern[]=*electron-builder*
public-hoist-pattern[]=*electron-rebuild*
public-hoist-pattern[]=*esbuild*
public-hoist-pattern[]=*node-abi*
shamefully-hoist=true
enable-pre-post-scripts=true