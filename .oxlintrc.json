{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_"
      }
    ],
    "no-useless-escape": "off"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": [
    "dist/**",
    "release/**",
    "node_modules/**",
    "renderer/audio/pcm-stream-processor.js"
  ]
}
